{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "consumer"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "consumer"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "consumer"
      }
    },
    "enterprise-development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "enterprise"
      }
    },
    "enterprise-preview": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "enterprise"
      }
    },
    "enterprise-production": {
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "enterprise"
      }
    }
  },
  "submit": {
    "production": {},
    "enterprise-production": {}
  }
}
