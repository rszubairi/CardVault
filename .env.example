# Convex
EXPO_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Google OAuth
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your-web-client-id.apps.googleusercontent.com

# LinkedIn OAuth
EXPO_PUBLIC_LINKEDIN_CLIENT_ID=your-linkedin-client-id

# Google Vision API (cloud fallback)
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# OpenAI (for AI message generation)
OPENAI_API_KEY=your-openai-api-key

# Stripe
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PERSONAL_PRO_PRICE_ID=price_your_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id
